@{
    ViewData["Title"] = "Quản Trị Hệ Thống";
}

<div class="container-fluid mt-4">
    <h2 class="text-primary fw-bold mb-4">Báo Cáo Cửa Hàng</h2>

    <div class="row mb-4 text-white">
        <div class="col-md-3"><div class="card bg-primary p-3 shadow-sm"><h6>Doanh Thu</h6><h4 id="sum-rev">...</h4></div></div>
        <div class="col-md-3"><div class="card bg-success p-3 shadow-sm"><h6>Đơn Hàng</h6><h4 id="sum-ord">0</h4></div></div>
        <div class="col-md-3"><div class="card bg-info p-3 shadow-sm"><h6>Sản Phẩm</h6><h4 id="sum-pro">0</h4></div></div>
        <div class="col-md-3"><div class="card bg-warning p-3 shadow-sm"><h6>Thành Viên</h6><h4 id="sum-cus">0</h4></div></div>
    </div>

    <div class="row">
        <div class="col-md-8"><div class="card p-3 shadow-sm"><canvas id="revChart" style="height:300px"></canvas></div></div>
        <div class="col-md-4"><div class="card p-3 shadow-sm"><canvas id="pieChart" style="height:300px"></canvas></div></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const formatVND = (v) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(v);

        fetch('@Url.Action("GetDashboardSummary", "Admin")').then(r => r.json()).then(d => {
            document.getElementById('sum-rev').innerText = formatVND(d.revenue);
            document.getElementById('sum-ord').innerText = d.orders;
            document.getElementById('sum-pro').innerText = d.products;
            document.getElementById('sum-cus').innerText = d.customers;
        });

        fetch('@Url.Action("GetRevenueData", "Admin")').then(r => r.json()).then(d => {
            new Chart(document.getElementById('revChart'), {
                type: 'line',
                data: { labels: d.map(i => i.label), datasets: [{ label: 'Doanh thu', data: d.map(i => i.value), borderColor: '#4e73df', fill: true, tension: 0.3 }] }
            });
        });

        fetch('@Url.Action("GetTopProducts", "Admin")').then(r => r.json()).then(d => {
            new Chart(document.getElementById('pieChart'), {
                type: 'doughnut',
                data: { labels: d.map(i => i.productName), datasets: [{ data: d.map(i => i.quantity), backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b'] }] }
            });
        });
    </script>
}